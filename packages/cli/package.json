{
  "name": "@evolve/cli",
  "version": "1.0.0",
  "bin": {
    "evolve": "./bin.js"
  },
  "scripts": {
    "build": "rspack -c scripts/rspack.config.ts",
    "build:tsc": "tsc --build",
    "test": "node --require tsx/cjs --test __tests__/*.test.ts",
    "watch:tsc": "tsc --watch",
    "dev": "node --env-file ../../.env ./bin.js"
  },
  "dependencies": {
    "@evolve/core": "workspace:*",
    "ink": "catalog:",
    "react": "catalog:",
    "react-devtools-core": "catalog:",
    "yargs": "catalog:"
  },
  "devDependencies": {
    "@rspack/cli": "catalog:",
    "@rspack/core": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
